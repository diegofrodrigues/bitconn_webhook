<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="bitconn_webhook.TerminalAction">
        <div class="o_bitconn_terminal_fullpage d-flex flex-column" style="height: calc(100vh - 56px); background: #000; padding: 12px; box-sizing: border-box;">
            <div class="o_bitconn_terminal_container d-flex flex-column" t-ref="terminalContainer" style="flex: 1; min-height: 0;">
                <div id="bitconn_terminal_banner" class="alert alert-warning" style="display:none;margin-bottom:8px;" role="alert">
                    Session expired. Click <strong>Connect</strong> to start a new session.
                </div>
                <div id="bitconn_terminal" class="xterm" style="flex: 1; min-height: 0; overflow: hidden;"></div>
                <div class="d-flex mt-2 gap-2">
                    <a href="#" role="button" class="btn btn-secondary o_bitconn_terminal_connect"><i class="fa fa-terminal me-1"/>Connect</a>
                    <a href="#" role="button" class="btn btn-secondary o_bitconn_terminal_shell"><i class="fa fa-code me-1"/>Shell</a>
                    <a href="#" role="button" class="btn btn-danger o_bitconn_terminal_disconnect" style="display:none;">Disconnect</a>
                    <a href="#" role="button" class="btn btn-secondary o_bitconn_terminal_clear"><i class="fa fa-eraser me-1"/>Clear</a>
                    <a href="#" role="button" class="btn btn-secondary o_bitconn_terminal_fullscreen"><i class="fa fa-expand me-1"/>Fullscreen</a>
                </div>
            </div>
        </div>
    </t>

</templates>
